function flashToast(msg) {
  var el = document.createElement("div");
  el.className = "toast";
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(function() { el.style.opacity = "0"; }, 1900);
  setTimeout(function() { el.remove(); }, 2300);
}

function burstConfetti() {
  var colors = ["#FFB3CB", "#A5D8FF", "#96F2D7", "#FFE066", "#D0BFFF"];
  for (var i = 0; i < 24; i++) {
    (function(i) {
      var piece = document.createElement("div");
      var left = Math.random() * 100;
      var delay = Math.random() * 0.4;
      var dur = 1.2 + Math.random() * 0.8;
      var color = colors[i % colors.length];
      piece.style.position = "fixed";
      piece.style.left = left + "%";
      piece.style.top = "-10px";
      piece.style.width = "8px";
      piece.style.height = "8px";
      piece.style.background = color;
      piece.style.borderRadius = i % 2 === 0 ? "50%" : "2px";
      piece.style.zIndex = "999";
      piece.style.pointerEvents = "none";
      piece.style.animation = "fall " + dur + "s " + delay + "s ease-in forwards";
      document.body.appendChild(piece);
      setTimeout(function() { piece.remove(); }, (dur + delay) * 1000 + 100);
    })(i);
  }
}
var styleTag = document.createElement("style");
styleTag.textContent = "@keyframes fall { to { transform: translateY(110vh) rotate(360deg); opacity: 0.3; } }";
document.head.appendChild(styleTag);

// ====================== AVATAR (blob chibi, dress-up) ======================
