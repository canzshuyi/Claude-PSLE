function render() {
  var app = document.getElementById("app");
  var tabHtml = "";
  if (currentTab === "home") tabHtml = renderHome();
  else if (currentTab === "tasks") tabHtml = renderTasks();
  else if (currentTab === "errors") tabHtml = renderErrors();
  else if (currentTab === "vocab") tabHtml = renderVocab();
  else if (currentTab === "timer") tabHtml = renderTimer();
  else if (currentTab === "shop") tabHtml = renderShop();

  app.innerHTML = renderHeader() + renderNav() + '<div>' + tabHtml + '</div>' +
    (showNamePrompt ? renderNamePromptModal() : '') +
    (showJourneyModal ? renderJourneyModal() : '') +
    (viewingError ? renderViewingErrorModal() : '');
  attachListeners();
}

