function renderHome() {
  var stage = getStage(state.stars);
  var upcoming = nextStage(state.stars);
  var progress = upcoming ? Math.min(100, ((state.stars - stage.min) / (upcoming.min - stage.min)) * 100) : 100;
  var dw = daysWeeksUntil(PSLE_DATE);
  var now = Date.now();
  var thisWeekKey = weekKey(now);
  var lastWeekKey = weekKey(now - 7 * 86400000);
  var tasksThisWeek = 0, tasksLastWeek = 0, masteredThisWeek = 0, vocabThisWeek = 0;
  for (var i = 0; i < state.tasks.length; i++) {
    var t = state.tasks[i];
    if (t.done && t.completedAt) {
      if (weekKey(t.completedAt) === thisWeekKey) tasksThisWeek++;
      if (weekKey(t.completedAt) === lastWeekKey) tasksLastWeek++;
    }
  }
  for (var j = 0; j < state.errorBank.length; j++) {
    var er = state.errorBank[j];
    if (er.mastered && weekKey(er.createdAt) === thisWeekKey) masteredThisWeek++;
  }
  for (var k = 0; k < state.vocabBank.length; k++) {
    if (weekKey(state.vocabBank[k].createdAt) === thisWeekKey) vocabThisWeek++;
  }
  var taskDelta = tasksThisWeek - tasksLastWeek;
  var bg = null;
  for (var b = 0; b < BACKGROUNDS.length; b++) { if (BACKGROUNDS[b].id === state.equippedBackground) bg = BACKGROUNDS[b]; }
  if (!bg) bg = BACKGROUNDS[0];

  var motivationalMsgs = [
