    bow: '<span style="position:absolute;top:-4%;left:50%;transform:translateX(-50%);font-size:' + (size*0.26) + 'px;z-index:3;">🎀</span>',
    cap: '<span style="position:absolute;top:-10%;left:50%;transform:translateX(-50%);font-size:' + (size*0.34) + 'px;z-index:3;">🧢</span>',
    glasses: '<span style="position:absolute;top:30%;left:50%;transform:translateX(-50%);font-size:' + (size*0.3) + 'px;z-index:2;">🤓</span>',
    scarf: '<span style="position:absolute;top:58%;left:50%;transform:translateX(-50%);font-size:' + (size*0.28) + 'px;z-index:2;">🧣</span>',
    flower: '<span style="position:absolute;top:-8%;left:50%;transform:translateX(-50%);font-size:' + (size*0.28) + 'px;z-index:3;">💐</span>',
    bag: '<span style="position:absolute;bottom:6%;left:2%;font-size:' + (size*0.24) + 'px;z-index:2;">🎒</span>',
    ribbon: '<span style="position:absolute;bottom:10%;left:50%;transform:translateX(-50%);font-size:' + (size*0.24) + 'px;z-index:2;">🌈</span>',
    crown: '<span style="position:absolute;top:-14%;left:50%;transform:translateX(-50%);font-size:' + (size*0.3) + 'px;z-index:3;">👑</span>',
    wand: '<span style="position:absolute;bottom:14%;right:0%;font-size:' + (size*0.26) + 'px;z-index:2;">🪄</span>',
    cape: '<span style="position:absolute;bottom:0%;left:50%;transform:translateX(-50%);font-size:' + (size*0.36) + 'px;z-index:0;">🦸</span>',
    gem: '<span style="position:absolute;top:55%;right:4%;font-size:' + (size*0.2) + 'px;z-index:2;">💎</span>'
