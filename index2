function uid() { return Math.random().toString(36).slice(2, 10); }
function getStage(stars) {
  var stage = STAGES[0];
  for (var i = 0; i < STAGES.length; i++) { if (stars >= STAGES[i].min) stage = STAGES[i]; }
  return stage;
}
function nextStage(stars) {
  for (var i = 0; i < STAGES.length; i++) { if (STAGES[i].min > stars) return STAGES[i]; }
  return null;
}
function daysWeeksUntil(target) {
  var now = new Date();
  var diffMs = target.getTime() - now.getTime();
  var days = Math.max(0, Math.ceil(diffMs / 86400000));
  return { days: days, weeks: Math.floor(days / 7), remDays: days % 7 };
}
function startOfWeek(d) {
  var date = new Date(d);
  var day = date.getDay();
  date.setDate(date.getDate() - day + (day === 0 ? -6 : 1));
  date.setHours(0, 0, 0, 0);
  return date;
}
function weekKey(ts) { return startOfWeek(new Date(ts)).toISOString().slice(0, 10); }
function escapeHtml(str) {
  if (!str) return "";
  return String(str).split("&").join("&amp;").split("<").join("&lt;").split(">").join("&gt;").split('"').join("&quot;");
}

var STORAGE_KEY = "eva-study-garden-state";
var DEFAULT_STATE = {
  avatarName: "",
  stars: 0,
  carrots: 0,
  streak: 0,
  lastCompletionDate: null,
  freezeAvailable: true,
  ownedAccessories: [],
  equippedAccessories: [],
  ownedBackgrounds: ["bg_default"],
  equippedBackground: "bg_default",
  tasks: [],
  errorBank: [],
  vocabBank: [],
  papers: []
};

function loadState() {
  try {
    var raw = localStorage.getItem(STORAGE_KEY);
    if (raw) {
      var parsed = JSON.parse(raw);
      var merged = {};
      for (var k in DEFAULT_STATE) merged[k] = DEFAULT_STATE[k];
      for (var k2 in parsed) merged[k2] = parsed[k2];
      return merged;
    }
  } catch (e) { console.error("load failed", e); }
  return null;
}
function saveState() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); }
  catch (e) { console.error("save failed", e); }
}

// ---- Free dictionary lookup (no key, no login needed) ----
function lookupDictionary(word) {
  return fetch("https://api.dictionaryapi.dev/api/v2/entries/en/" + encodeURIComponent(word.toLowerCase()))
    .then(function(res) {
      if (!res.ok) throw new Error("NOT_FOUND");
      return res.json();
    })
    .then(function(data) {
      var entry = data[0];
      var definition = "";
      var example = "";
      var partOfSpeech = "";
      if (entry && entry.meanings && entry.meanings.length) {
        for (var i = 0; i < entry.meanings.length; i++) {
          var m = entry.meanings[i];
          if (m.definitions && m.definitions.length) {
            partOfSpeech = m.partOfSpeech || "";
            definition = m.definitions[0].definition || "";
            example = m.definitions[0].example || "";
            break;
          }
        }
      }
      return { definition: definition, example: example, partOfSpeech: partOfSpeech };
    });
}

function readFileAsDataURL(file) {
  return new Promise(function(resolve, reject) {
    var reader = new FileReader();
    reader.onload = function() { resolve(reader.result); };
    reader.onerror = reject;
    reader.readAsDataURL(file);
  });
}

