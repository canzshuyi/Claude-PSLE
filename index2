  for (var i = 0; i < equipped.length; i++) { if (accMap[equipped[i]]) accHtml += accMap[equipped[i]]; }

  return '<div style="width:' + size + 'px;height:' + size + 'px;border-radius:50%;background:' + bgCss + ';' +
    'display:flex;align-items:center;justify-content:center;position:relative;' +
    'box-shadow:0 6px 20px rgba(255,179,203,0.4);border:4px solid white;margin:0 auto;overflow:visible;">' +
