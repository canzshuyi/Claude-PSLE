    html += '<div class="empty"><div class="emoji">⏱</div><div class="text">Pick a PSLE paper below to start an exam timer.</div></div>';
  }
  html += '<div style="margin-top:14px;display:flex;flex-direction:column;gap:8px;">';
  for (var k = 0; k < TIMERS.length; k++) {
    var tm = TIMERS[k];
    html += '<button data-start-timer="' + tm.id + '" style="display:flex;justify-content:space-between;align-items:center;background:white;border:none;border-radius:12px;padding:12px 14px;box-shadow:0 2px 8px rgba(0,0,0,0.04);cursor:pointer;text-align:left;">' +
      '<span style="font-size:13px;font-weight:700;color:#495057;">' + tm.label + '</span><span style="font-size:12px;color:#adb5bd;">' + tm.mins + ' min</span></button>';
  }
  html += '</div>';
  return html;
}
function startTimer(id) {
  var t = null;
  for (var i = 0; i < TIMERS.length; i++) { if (TIMERS[i].id === id) t = TIMERS[i]; }
  if (!t) return;
  timerActiveId = id;
  timerSecondsLeft = t.mins * 60;
  timerRunning = true;
  clearInterval(timerInterval);
  timerInterval = setInterval(function() {
    timerSecondsLeft -= 1;
    if (timerSecondsLeft <= 0) { timerSecondsLeft = 0; timerRunning = false; clearInterval(timerInterval); }
    render();
  }, 1000);
  render();
}
function timerPauseResume() {
  timerRunning = !timerRunning;
  if (timerRunning) {
    clearInterval(timerInterval);
    timerInterval = setInterval(function() {
      timerSecondsLeft -= 1;
      if (timerSecondsLeft <= 0) { timerSecondsLeft = 0; timerRunning = false; clearInterval(timerInterval); }
      render();
    }, 1000);
  } else {
    clearInterval(timerInterval);
  }
  render();
}
// FIX: Reset now restarts the SAME paper's countdown instead of closing
// the timer view back to the picker list.
function timerReset() {
  clearInterval(timerInterval);
  var t = null;
  for (var i = 0; i < TIMERS.length; i++) { if (TIMERS[i].id === timerActiveId) t = TIMERS[i]; }
  if (t) {
    timerSecondsLeft = t.mins * 60;
    timerRunning = false;
  }
  render();
}
function timerClose() {
  clearInterval(timerInterval);
  timerActiveId = null; timerSecondsLeft = 0; timerRunning = false;
  render();
}

// ====================== SHOP (clothes + backgrounds) ======================
function renderShop() {
  var html = '<div style="text-align:center;margin-bottom:12px;font-size:13px;color:#868e96;">Spend your Carrots 🥕 on clothes and backgrounds for your buddy!</div>';
  html += '<div class="tab-toggle">';
  html += '<button data-shop-tab="clothes" style="background:' + (shopSubTab==='clothes'?'#FFB3CB':'white') + ';color:' + (shopSubTab==='clothes'?'white':'#868e96') + ';">🎀 Clothes</button>';
  html += '<button data-shop-tab="backgrounds" style="background:' + (shopSubTab==='backgrounds'?'#FFB3CB':'white') + ';color:' + (shopSubTab==='backgrounds'?'white':'#868e96') + ';">🎨 Backgrounds</button>';
  html += '</div>';

  if (shopSubTab === 'clothes') {
    var sorted = ACCESSORIES.slice().sort(function(a,b){ return a.cost - b.cost; });
    html += '<div class="shop-grid">';
    for (var i = 0; i < sorted.length; i++) {
      var item = sorted[i];
      var owned = state.ownedAccessories.indexOf(item.id) !== -1;
      var equipped = state.equippedAccessories.indexOf(item.id) !== -1;
      html += '<div class="shop-item"><div style="font-size:30px;">' + item.emoji + '</div><div style="font-size:12px;font-weight:700;color:#495057;margin-top:4px;">' + item.name + '</div>';
      if (!owned) {
        html += '<button data-buy-acc="' + item.id + '" style="margin-top:8px;width:100%;background:#FFD8A8;color:#9C6B00;border:none;border-radius:10px;padding:6px;font-weight:700;font-size:12px;cursor:pointer;">🥕 ' + item.cost + '</button>';
      } else {
        html += '<button data-equip-acc="' + item.id + '" style="margin-top:8px;width:100%;background:' + (equipped?'#82c91e':'#E9ECEF') + ';color:' + (equipped?'white':'#868e96') + ';border:none;border-radius:10px;padding:6px;font-weight:700;font-size:12px;cursor:pointer;">' + (equipped?'Equipped ✓':'Equip') + '</button>';
      }
      html += '</div>';
    }
    html += '</div>';
  } else {
    html += '<div class="bg-grid" style="margin-top:0;">';
    for (var b = 0; b < BACKGROUNDS.length; b++) {
      var bg = BACKGROUNDS[b];
      var ownedBg = state.ownedBackgrounds.indexOf(bg.id) !== -1;
      var equippedBg = state.equippedBackground === bg.id;
      html += '<div class="bg-item" style="background:' + bg.css + ';"><div style="background:rgba(255,255,255,0.85);border-radius:10px;padding:8px;">';
      html += '<div style="font-size:12px;font-weight:700;color:#495057;">' + bg.name + '</div>';
      if (!ownedBg) {
        html += '<button data-buy-bg="' + bg.id + '" style="margin-top:8px;width:100%;background:#FFD8A8;color:#9C6B00;border:none;border-radius:10px;padding:6px;font-weight:700;font-size:12px;cursor:pointer;">🥕 ' + bg.cost + '</button>';
      } else {
        html += '<button data-equip-bg="' + bg.id + '" style="margin-top:8px;width:100%;background:' + (equippedBg?'#82c91e':'#E9ECEF') + ';color:' + (equippedBg?'white':'#868e96') + ';border:none;border-radius:10px;padding:6px;font-weight:700;font-size:12px;cursor:pointer;">' + (equippedBg?'Equipped ✓':'Equip') + '</button>';
      }
      html += '</div></div>';
    }
    html += '</div>';
  }
  return html;
}
function buyAccessory(id) {
  var item = null;
  for (var i = 0; i < ACCESSORIES.length; i++) { if (ACCESSORIES[i].id === id) item = ACCESSORIES[i]; }
  if (!item) return;
  if (state.carrots < item.cost) { flashToast("Not enough carrots yet! Keep completing tasks 🥕"); return; }
  state.carrots -= item.cost;
  state.ownedAccessories.push(id);
  flashToast("Bought " + item.name + "!");
  persist(); render();
}
function equipAccessory(id) {
  var idx = state.equippedAccessories.indexOf(id);
  if (idx !== -1) state.equippedAccessories.splice(idx, 1);
  else state.equippedAccessories.push(id);
  persist(); render();
}
function buyBackground(id) {
  var bg = null;
  for (var i = 0; i < BACKGROUNDS.length; i++) { if (BACKGROUNDS[i].id === id) bg = BACKGROUNDS[i]; }
  if (!bg) return;
  if (state.carrots < bg.cost) { flashToast("Not enough carrots yet! Keep completing tasks 🥕"); return; }
  state.carrots -= bg.cost;
  state.ownedBackgrounds.push(id);
  flashToast("Unlocked " + bg.name + "!");
  persist(); render();
}
function equipBackground(id) {
  state.equippedBackground = id;
  persist(); render();
}

function renderNamePromptModal() {
