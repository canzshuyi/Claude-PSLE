  var html = '';
  html += '<div class="card" style="text-align:center;padding:20px;">';
  html += '<div id="avatarNameClick" style="font-size:13px;font-weight:700;color:#D6336C;margin-bottom:8px;cursor:pointer;">' + escapeHtml(state.avatarName || "Your Buddy") + ' ✏️</div>';
  html += '<div id="avatarClick" style="cursor:pointer;">' + avatarHtml(state.equippedAccessories, 120, bg.css) + '</div>';
  html += '<div style="margin-top:10px;font-weight:800;font-size:17px;color:#495057;">' + stage.name + '</div>';
  html += '<div style="font-size:11px;color:#bdb8ce;margin-top:2px;">(Tap your buddy to see your growth journey)</div>';
  html += '<div style="font-size:12px;color:#adb5bd;margin-top:6px;">' + (upcoming ? ((upcoming.min - state.stars) + ' ⭐ to reach ' + upcoming.name) : "Top rank reached! 🎉") + '</div>';
  html += '<div style="background:#f1f3f5;border-radius:10px;height:10px;margin-top:10px;overflow:hidden;"><div style="width:' + progress + '%;height:100%;background:linear-gradient(90deg,#FFB3CB,#A5D8FF);border-radius:10px;"></div></div>';
  html += '<button class="btn-secondary" id="shareCardBtn" style="margin-top:16px;">📤 Share Avatar Card</button>';
  html += '</div>';

