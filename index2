  html += '<div style="font-size:40px;">🌱</div><div style="font-weight:800;font-size:16px;color:#D6336C;margin-top:8px;">Name your Study Buddy!</div>';
  html += '<div style="font-size:12px;color:#868e96;margin-top:4px;">Give your little companion a cute name</div>';
  html += '<input id="nameInput" placeholder="e.g. Mochi, Pip, Sunny..." style="width:100%;margin-top:14px;box-sizing:border-box;text-align:center;border:2px solid #FFE3EC;" />';
  html += '<button class="btn-primary" id="saveNameBtn" style="margin-top:14px;width:100%;">Let\\'s go! ✨</button></div></div>';
