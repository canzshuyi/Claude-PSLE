function toggleTask(id) {
  var task = null;
  for (var i = 0; i < state.tasks.length; i++) { if (state.tasks[i].id === id) task = state.tasks[i]; }
  if (!task) return;
  var willBeDone = !task.done;
  task.done = willBeDone;
  task.completedAt = willBeDone ? Date.now() : null;
  if (willBeDone) {
    state.stars += 2;
    state.carrots += 1;
    var today = new Date().toDateString();
    if (state.lastCompletionDate !== today) {
      var yesterday = new Date(Date.now() - 86400000).toDateString();
      if (state.lastCompletionDate === yesterday) {
        state.streak += 1;
      } else if (state.freezeAvailable && state.lastCompletionDate) {
        state.streak += 1;
        state.freezeAvailable = false;
      } else {
        state.streak = 1;
      }
      state.lastCompletionDate = today;
      if (state.streak > 0 && state.streak % 7 === 0) state.freezeAvailable = true;
    }
    burstConfetti();
    flashToast("+2 ⭐ +1 🥕 Task complete!");
  } else {
    state.stars = Math.max(0, state.stars - 2);
    state.carrots = Math.max(0, state.carrots - 1);
  }
  persist();
  render();
}
function deleteTask(id) {
