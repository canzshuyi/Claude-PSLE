<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eva's Study Garden</title>
<style>
  * { box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', system-ui, sans-serif;
    background: linear-gradient(180deg, #FFF7FB 0%, #F3F8FF 100%);
    margin: 0;
    padding: 16px;
    color: #495057;
  }
  #app { max-width: 480px; margin: 0 auto; position: relative; }
  .card { background: white; border-radius: 14px; padding: 12px; margin-bottom: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .title { font-size: 18px; font-weight: 800; color: #D6336C; }
  .pills { display: flex; gap: 8px; }
  .pill { background: white; border-radius: 20px; padding: 4px 10px; font-size: 13px; font-weight: 700; display: flex; align-items: center; gap: 4px; color: #495057; }
  .navbar { display: flex; overflow-x: auto; gap: 6px; padding-bottom: 4px; margin-bottom: 12px; }
  .navbtn { flex-shrink: 0; border: none; background: white; color: #868e96; border-radius: 14px; padding: 8px 12px; font-size: 12px; font-weight: 700; cursor: pointer; display: flex; flex-direction: column; align-items: center; gap: 2px; min-width: 56px; }
  .navbtn.active { background: #FFB3CB; color: white; }
  .navbtn .emoji { font-size: 16px; }
  button { font-family: inherit; }
  input, select, textarea { font-family: inherit; border-radius: 10px; border: 2px solid #eee; padding: 8px 10px; font-size: 13px; }
  textarea { resize: vertical; }
  .empty { text-align: center; padding: 30px 10px; color: #adb5bd; }
  .empty .emoji { font-size: 32px; }
  .empty .text { font-size: 13px; margin-top: 6px; }
  .toast { position: fixed; top: 16px; left: 50%; transform: translateX(-50%); background: #fff; border: 2px solid #FFB3CB; border-radius: 14px; padding: 8px 16px; font-size: 14px; font-weight: 600; color: #D6336C; z-index: 60; box-shadow: 0 4px 14px rgba(0,0,0,0.1); transition: opacity 0.3s; }
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.4); display: flex; align-items: center; justify-content: center; z-index: 70; padding: 20px; }
  .modal-box { background: white; border-radius: 20px; padding: 24px; max-width: 340px; max-height: 85vh; overflow-y: auto; text-align: center; box-shadow: 0 10px 40px rgba(0,0,0,0.2); }
  .btn-primary { background: #FFB3CB; color: white; border: none; border-radius: 12px; padding: 10px 18px; font-weight: 700; font-size: 13px; cursor: pointer; }
  .btn-secondary { background: #FFE3EC; color: #D6336C; border: none; border-radius: 12px; padding: 10px 18px; font-weight: 700; font-size: 13px; cursor: pointer; }
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
  .stat-box { background: white; border-radius: 12px; padding: 10px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .stat-box .emoji { font-size: 18px; }
  .stat-box .value { font-weight: 800; font-size: 16px; color: #495057; }
  .stat-box .label { font-size: 10px; color: #adb5bd; }
  .subject-pill { font-size: 9px; font-weight: 700; border-radius: 8px; padding: 2px 6px; }
  .err-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .err-card { background: white; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .err-card img { width: 100%; height: 110px; object-fit: cover; cursor: pointer; display: block; }
  .err-card .body { padding: 8px; }
  .task-row { display: flex; align-items: center; gap: 8px; background: white; border-radius: 12px; padding: 10px; margin-bottom: 6px; box-shadow: 0 2px 6px rgba(0,0,0,0.04); }
  .shop-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .shop-item { background: white; border-radius: 14px; padding: 12px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .bg-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; }
  .bg-item { border-radius: 14px; padding: 12px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,0.04); position: relative; overflow: hidden; }
  .journey-stage { display: flex; align-items: center; gap: 10px; padding: 10px; border-radius: 12px; margin-bottom: 6px; }
  .vocab-card { background: white; border-radius: 12px; padding: 12px; margin-bottom: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); cursor: pointer; }
  .upload-label { display: block; text-align: center; color: white; border-radius: 10px; padding: 10px; font-weight: 700; font-size: 13px; cursor: pointer; }
  .tab-toggle { display: flex; gap: 6px; margin-bottom: 12px; }
  .tab-toggle button { flex: 1; border: none; border-radius: 10px; padding: 8px; font-size: 12px; font-weight: 700; cursor: pointer; }
  ::-webkit-scrollbar { height: 4px; }
</style>
</head>
